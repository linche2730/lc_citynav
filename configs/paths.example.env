# Copy this file to paths.local.env or paths.server.env.
# Default layout keeps code and data together under this project directory.
# Run scripts from the project root, or use wrappers that export PROJECT_ROOT.

DATA_BASE=${PROJECT_ROOT:-$(pwd)}/data

CITYNAV_DATA_ROOT=${DATA_BASE}/citynav
CITYREFER_DATA_DIR=${CITYNAV_DATA_ROOT}/cityrefer
CITYNAV_ANNOTATION_DIR=${CITYNAV_DATA_ROOT}/citynav
CITYNAV_RGBD_DIR=${CITYNAV_DATA_ROOT}/rgbd-new
CITYNAV_GSAM_DIR=${CITYNAV_DATA_ROOT}/gsam
CITYNAV_SUBBLOCKS_DIR=${CITYNAV_DATA_ROOT}/subblocks
CITYNAV_WEIGHTS_ROOT=${DATA_BASE}/weights
CITYNAV_CHECKPOINT_ROOT=${DATA_BASE}/checkpoints
CITYNAV_MGP_CHECKPOINT=${CITYNAV_CHECKPOINT_ROOT}/goal_predictor/mgp_mturk.pth

FLIGHTGPT_DATA_ROOT=${DATA_BASE}/flightgpt_data
FLIGHTGPT_TRAIN_DATA_ROOT=${FLIGHTGPT_DATA_ROOT}/training_data
FLIGHTGPT_MODEL_ROOT=${DATA_BASE}/model_weight
FLIGHTGPT_OUTPUT_ROOT=${DATA_BASE}/outputs
FLIGHTGPT_PHOTO_ROOT=${DATA_BASE}/R1PhotoData

QWEN25_VL_ROOT=${FLIGHTGPT_MODEL_ROOT}/Qwen2.5-VL-7B-Instruct
FLIGHTGPT_SFT_ROOT=${FLIGHTGPT_MODEL_ROOT}/Flightgpt_SFT
FLIGHTGPT_FINAL_ROOT=${FLIGHTGPT_MODEL_ROOT}/Flightgpt

HF_HOME=${DATA_BASE}/hf_home
VLLM_API_BASE=http://127.0.0.1:8888/v1
VLLM_API_KEY=EMPTY
VLLM_API_VERSION=2024-05-01-preview
VLLM_MODEL_NAME=qwen_2_5_vl_7b

CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
NPROC_PER_NODE=8
RUNS_ROOT=${DATA_BASE}/runs
